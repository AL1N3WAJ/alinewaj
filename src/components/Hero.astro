---
import Starfield from './Starfield.astro';
---

<section class="min-h-screen flex items-center justify-center relative px-6">
  <Starfield />
  <div class="max-w-4xl mx-auto text-center z-10">
    <h1 class="text-5xl md:text-7xl font-bold font-heading tracking-tighter">
      Hi, I'm <span class="text-space-accent">Ali Newaj</span>
    </h1>
    <p class="mt-6 text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto">
      Physics undergraduate exploring the universe through code, simulations, and astrophotography.
    </p>
    <div class="mt-12 flex gap-4 justify-center flex-wrap">
      <a href="#projects" class="px-8 py-4 bg-space-accent hover:bg-violet-600 rounded-2xl font-medium text-lg transition">View Projects</a>
      <a href="#contact" class="px-8 py-4 border border-white/30 hover:border-white/60 rounded-2xl font-medium text-lg transition">Get in Touch</a>
    </div>
  </div>
  <div class="absolute bottom-10 left-1/2 text-3xl animate-bounce">↓</div>
</section>
